# vLLM-Moet on official vLLM v0.25.1 — Ada / sm_89 (RTX 4090, RTX 2000-6000 Ada)
#
# The v0.25.1 LINEAGE of the Ada build: official vllm/vllm-openai:v0.25.1
# with the per-file patches under patches/ applied. Each patch touches one
# vLLM file; the patch set is generated by tools/gen_patches.py from the
# overlay/ folder (source of truth) diffed against the vllm/ baseline at
# the v0.25.1 tag (commit 752a3a504). The 2-bit MoE experts run through
# the same Triton emulation as the v0.24.0 Ada image (moe_w2_sm89.py,
# inside the patch set); the e8m0 Triton-MM decode fix is carried
# (v0.25.1 upstream still has the ROCm/XPU-only gate).
#
# STATUS: CPU-validated only (patch .py compile, packing golden, stream
# mechanics harness). The v0.24.0 image (Dockerfile.sm89-v024) is the
# field-tested line — its startup self-test passed on RTX 4090 D. Run
# the /opt/moet-checks op gate on silicon before trusting this one, and
# note DCP configs on this lineage follow upstream semantics (the moet
# DCP backports were superseded by upstream's evolution; revalidate
# before enabling DCP).
#
# Differences vs Dockerfile.sm89-v024:
#   - base image v0.25.1
#   - patches/ (per-file; 10 of the v0.24.0 lineage's files were
#     absorbed upstream, DSpark among them)
#   - flashinfer 0.6.14 pin RESTORED (field-proven necessary): vllm
#     0.25.1 pins flashinfer 0.6.13 in-image, but its own DSV4 sparse
#     call sites pass the SWA kwargs (swa_topk_lens) that FlashInfer
#     grew in 0.6.14 - decode warmup dies with an unexpected-keyword
#     TypeError on the sparse-MLA-API mode (the SM12x mode; SM100's
#     trtllm-gen mode dodges it, which is how upstream's lag survives
#     their CI). The engine also probes the signature at init now and
#     refuses loudly on an old FlashInfer.
#   - DSv4 sparse-MLA attention on Ada does NOT run FlashInfer at all:
#     FlashInfer's deepest gate (_resolve_dsv4_sparse_mla_backend)
#     refuses everything below SM100 (field-hit at decode capture).
#     Decode AND prefill route to vLLM's Triton port
#     (vllm/v1/attention/ops/triton_sparse_mla_dsv4.py, in the patch),
#     verified against a torch reference by an init-time on-device
#     self-test. VLLM_DSV4_SPARSE_MLA_FORCE_TRITON=1 forces that port
#     on any arch; VLLM_DSV4_SPARSE_MLA_SELFTEST=0 skips the self-test
#     (triage only). The pin above still matters for everything else
#     FlashInfer serves in this image.
#
# Build (from the repo root):
#   DOCKER_BUILDKIT=1 docker build -f Dockerfile.sm89-v0251 -t vllm-moet-sm89:v0251 .
# Serve: same launcher, IMG override:
#   IMG=vllm-moet-sm89:v0251 docker/serve_sm89_ds4.sh

FROM vllm/vllm-openai:v0.25.1

# Native-crash observability (see Dockerfile.sm89-v024 for the rationale:
# "Failed core proc(s): {}" = no Python exception; faulthandler puts
# segfault/abort stacks into docker logs; OOM-kills still need host dmesg).
ENV PYTHONFAULTHANDLER=1

RUN apt-get update && apt-get install -y --no-install-recommends git \
    && rm -rf /var/lib/apt/lists/*

# flashinfer 0.6.14 (+ cu130 jit-cache): the image's 0.6.13 predates the
# DSV4 SWA kwargs (see header). The 0.6.13 cubin pkg must go - there is
# no 0.6.14 build of it and the version check would trip.
RUN pip uninstall -y --break-system-packages flashinfer-cubin || true
RUN pip install --no-cache-dir --break-system-packages flashinfer-python==0.6.14 \
    && pip install --no-cache-dir --break-system-packages \
        --index-url https://flashinfer.ai/whl/cu130 \
        "flashinfer-jit-cache==0.6.14+cu130"

# the v0.25.1-lineage patch set: per-file unified diffs under patches/,
# generated by tools/gen_patches.py from overlay/ diffed against the
# v0.25.1 baseline. Each patch touches one file; apply order is irrelevant.
# Refuses to build if patches/ is empty, MANIFEST.txt is missing, or the
# MANIFEST line count does not match the actual patch file count (R13).
COPY patches/ /tmp/patches/
RUN test -s /tmp/patches/MANIFEST.txt \
    || (echo "patches/MANIFEST.txt missing or empty - refusing to build" && exit 1)
RUN manifest_count=$(grep -v '^#' /tmp/patches/MANIFEST.txt | grep -c .) \
    && patch_count=$(ls /tmp/patches/*.patch 2>/dev/null | wc -l) \
    && [ "$manifest_count" = "$patch_count" ] \
    || (echo "patches/MANIFEST.txt lists $manifest_count entries but patches/ has $patch_count .patch files - regenerate via tools/gen_patches.py" && exit 1)
RUN cd "$(python3 -c 'import vllm, os; print(os.path.dirname(os.path.dirname(vllm.__file__)))')" \
    && git apply --verbose /tmp/patches/*.patch \
    && python3 -c "from vllm.model_executor.layers.quantization.utils import moe_w2_cubit; print('moe_w2 hook OK')" \
    && python3 -c "from vllm.model_executor.layers.quantization.utils import moe_w2_sm89; print('sm_89 triton kernels OK')" \
    && rm -rf /tmp/patches

# op-level check scripts + image identity (same contract as the v024 image:
# run the full gate on new silicon BEFORE serving; SOURCE names the upstream
# v0.25.1 SHA the patches/ set was diffed against)
COPY kernels/gen/moe_w2_check_sm89.py kernels/gen/moe_w2_sm89_cpu_check.py /opt/moet-checks/
COPY patches/SOURCE.txt /opt/moet-checks/SOURCE.txt
