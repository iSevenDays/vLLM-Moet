+@functools.lru_cache(maxsize=None)
+def _dsv4_sparse_mla_route(device: torch.device) -> str:
+    """Pick ``flashinfer`` or ``triton-port`` for DSv4 sparse MLA.
+
+    Mirrors FlashInfer's DEEPEST arch gate
+    (``_resolve_dsv4_sparse_mla_backend``: SM100/103 -> trtllm-gen,
+    SM120/121 -> sparse, everything else -> ValueError). Class names and
+    import/signature probes above that resolver have lied before: Ada
+    passed both and then died at decode graph capture, 41 s into boot.
+    Everything the resolver refuses routes to vLLM's Triton port
+    (``vllm/v1/attention/ops/triton_sparse_mla_dsv4.py``).
+
+    ``VLLM_DSV4_SPARSE_MLA_FORCE_TRITON=1`` forces the port on any arch
+    (A/B numerics and perf against the native kernels).
+    """
+    if os.getenv("VLLM_DSV4_SPARSE_MLA_FORCE_TRITON",
+                 "0").lower() in ("1", "true", "yes", "on"):
+        logger.warning_once(
+            "DSv4 sparse MLA: VLLM_DSV4_SPARSE_MLA_FORCE_TRITON=1 - using "
+            "the Triton port even where FlashInfer has native kernels.")
+        return "triton-port"
+    major, minor = torch.cuda.get_device_capability(device)
+    if major in (10, 12):
+        return "flashinfer"
+    logger.warning_once(
+        "DSv4 sparse MLA: FlashInfer's resolver has no sm_%d%d kernel "
+        "(supports SM100/SM103/SM120/SM121) - decode AND prefill route to "
+        "vLLM's Triton sparse-MLA port. Correct but slower than the native "
+        "kernels; a native port is the long-term fix.", major, minor)
+    return "triton-port"
+
+
+def flashinfer_trtllm_batch_decode_sparse_mla_dsv4(*args: Any,
+                                                   **kwargs: Any) -> Any:
+    """DSv4 sparse-MLA decode/prefill entry, routed by device arch.
+
+    SM100/SM103 and SM120/SM121 call FlashInfer natively; every other
+    arch takes the Triton port with identical call surface + semantics.
+    """
+    query = kwargs["query"] if "query" in kwargs else args[0]
+    if query.is_cuda and _dsv4_sparse_mla_route(query.device) == "triton-port":
+        from vllm.v1.attention.ops.triton_sparse_mla_dsv4 import (
+            triton_sparse_mla_dsv4)
+
+        return triton_sparse_mla_dsv4(*args, **kwargs)
+    return _flashinfer_native_trtllm_batch_decode_sparse_mla_dsv4(
+        *args, **kwargs)
 
 
